# Copy this file to .env and fill in your details before running docker compose up -d

# General
# Relative paths are resolved from the directory where docker-compose.yml lives.
DATA_ROOT=./data

# Optional profiles:
# - leave empty for local-only services
# - local-ollama runs Ollama inside Docker on the Pi
# - public-game enables Playit for game/public TCP or UDP exposure
# - public-http enables Traefik for local HTTP routing behind your host Cloudflare tunnel
# Example: COMPOSE_PROFILES=local-ollama,public-game,public-http
COMPOSE_PROFILES=

# Traefik host ports.
# Default HTTP router port is 8089 because port 80 is often already used by StellarMate.
TRAEFIK_HOST_PORT=8089
TRAEFIK_DASHBOARD_PORT=8088

# Quick Tunnel settings for the host-level cloudflared service.
# This is best used for temporary access to one app at a time. For your main
# homelab setup, use a host-managed Cloudflare tunnel that forwards to Traefik.
QUICK_TUNNEL_LOCAL_URL=http://127.0.0.1:3001
QUICK_TUNNEL_STATE_DIR=~/homelab/.quick-tunnel
QUICK_TUNNEL_TARGET_WAIT_SECONDS=300
QUICK_TUNNEL_CHECK_INTERVAL_SECONDS=10
QUICK_TUNNEL_SYNC_INTERVAL_SECONDS=600
QUICK_TUNNEL_RESTART_DELAY_SECONDS=10

# DuckDNS metadata publication for the current trycloudflare.com URL.
# This does NOT make DuckDNS redirect to the Quick Tunnel. It only stores the
# active URL in a DuckDNS TXT record so you can look it up from one stable name.
DUCKDNS_DOMAIN=your-subdomain
DUCKDNS_TOKEN=your_duckdns_token
PUBLISH_DUCKDNS_TXT=1
CLEAR_DUCKDNS_TXT_ON_STOP=0

# Public HTTP apps should use dedicated hostnames.
# Replace these example.com placeholders in your local .env when you are ready.
# Use stable hostnames here. Quick Tunnel trycloudflare hostnames are temporary and
# should not be treated as the permanent public URL for a multi-app stack.
PUBLIC_APP_SCHEME=https
ADMIN_PUBLIC_HOST=admin.example.com
ADMIN_PUBLIC_URL=https://admin.example.com
OPENWEBUI_PUBLIC_HOST=chat.example.com
OPENWEBUI_PUBLIC_URL=https://chat.example.com
OPENWEBUI_CORS_ALLOW_ORIGIN=https://chat.example.com;http://127.0.0.1:3001;http://localhost:3001

# Open WebUI -> Ollama connection
# Default points at host-installed Ollama on the Raspberry Pi.
# If you enable the local-ollama profile, you can change this to http://ollama:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Minecraft
MC_MEMORY=2G
MC_TYPE=VANILLA
MC_VERSION=LATEST

# Nextcloud AIO
# AIO includes PostgreSQL automatically, so you do not need to choose SQLite/MySQL/Postgres manually.
# The setup interface is exposed on https://<pi-ip>:8081.
# For public access behind a host-managed reverse proxy or Cloudflare Tunnel, point the drive hostname to http://127.0.0.1:11000.
NEXTCLOUD_AIO_APACHE_PORT=11000

# Open WebUI (set to a long random string, e.g. `openssl rand -hex 32`)
WEBUI_SECRET_KEY=replace_with_a_long_random_secret

# Admin Control
# Generate ADMIN_PASSWORD_HASH with: python scripts/hash_admin_password.py
# Important: keep the full hash wrapped in single quotes in .env because it contains `$`.
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH='replace_with_pbkdf2_hash'
ADMIN_SESSION_SECRET=replace_with_a_long_random_secret
ADMIN_SECURE_COOKIES=1
# Optional bearer token for GitHub Actions or webhook-driven automation.
ADMIN_API_TOKEN=

# Playit Docker agent secret key.
# Choose the Docker option in Playit, then paste that key here.
# Optional: only needed if you enable the public-game profile.
PLAYIT_SECRET_KEY=your_playit_secret_key_here
